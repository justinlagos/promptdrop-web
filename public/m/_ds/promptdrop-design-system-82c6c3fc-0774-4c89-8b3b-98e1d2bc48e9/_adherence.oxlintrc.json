{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/buttons/**",
              "components/display/**",
              "components/feedback/**",
              "components/forms/**",
              "components/promptdrop/**",
              "ui_kits/control-app/**",
              "ui_kits/prompt-drop/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color, use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value, use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Manrope|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Manrope, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|title|icon|key|ref|className|style|children)$/]",
        "message": "<Alert> doesn't accept that prop. Declared props: variant, title, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:info|success|warning|error)$/]",
        "message": "<Alert> variant must be one of 'info' | 'success' | 'warning' | 'error'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|src|size|accent|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: name, src, size, accent."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Avatar> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|dot|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, dot."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:neutral|accent|success|warning|error|recording)$/]",
        "message": "<Badge> variant must be one of 'neutral' | 'accent' | 'success' | 'warning' | 'error' | 'recording'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|iconLeft|iconRight|loading|fullWidth|as|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, iconLeft, iconRight, loading, fullWidth, as."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|destructive|recording|launch)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'destructive' | 'recording' | 'launch'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|padded|interactive|selected|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: variant, padded, interactive, selected."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|accent|ghost)$/]",
        "message": "<Card> variant must be one of 'default' | 'accent' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|label|children|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: variant, size, label, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:ghost|solid|accent|fab)$/]",
        "message": "<IconButton> variant must be one of 'ghost' | 'solid' | 'accent' | 'fab'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|error|icon|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, error, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='PromptCharacter'] > JSXAttribute > JSXIdentifier[name!=/^(?:state|size|color|key|ref|className|style|children)$/]",
        "message": "<PromptCharacter> doesn't accept that prop. Declared props: state, size, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='PromptDrop'] > JSXAttribute > JSXIdentifier[name!=/^(?:state|title|lines|index|count|message|recording|progress|showCharacter|width|height|charSize|onPlay|actions|key|ref|className|style|children)$/]",
        "message": "<PromptDrop> doesn't accept that prop. Declared props: state, title, lines, index, count, message, recording, progress, showCharacter, width, height, charSize, onPlay, actions."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentedOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|icon|key|ref|className|style|children)$/]",
        "message": "<SegmentedOption> doesn't accept that prop. Declared props: value, label, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='SelectOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<SelectOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Slider'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|min|max|step|suffix|formatValue|key|ref|className|style|children)$/]",
        "message": "<Slider> doesn't accept that prop. Declared props: label, value, min, max, step, suffix, formatValue."
      },
      {
        "selector": "JSXOpeningElement[name.name='Spinner'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|label|key|ref|className|style|children)$/]",
        "message": "<Spinner> doesn't accept that prop. Declared props: size, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|label|spread|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, label, spread."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:active|onRemove|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: active, onRemove."
      },
      {
        "selector": "JSXOpeningElement[name.name='Textarea'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|editor|key|ref|className|style|children)$/]",
        "message": "<Textarea> doesn't accept that prop. Declared props: label, editor."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|title|description|loading|onClose|key|ref|className|style|children)$/]",
        "message": "<Toast> doesn't accept that prop. Declared props: variant, title, description, loading, onClose."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:info|success|error)$/]",
        "message": "<Toast> variant must be one of 'info' | 'success' | 'error'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
