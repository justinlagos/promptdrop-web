# Copy to .env. Only VITE_* values reach the client; all of these are client-safe.
VITE_APP_ENV=production

# Supabase (project URL + publishable/anon key — safe to expose)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx

# Desktop download (optional)
VITE_DMG_URL=
VITE_DMG_VERSION=

# Meeting intelligence (Phase 3; adapters present, inactive until set)
VITE_TRANSCRIPTION_ENDPOINT=
VITE_ASSISTANT_ENDPOINT=

# Dev only: never set in production
VITE_DEV_UNLOCK_PLAN=

# ---- SEO ----
# Production origin used for canonical URLs and OG urls.
# Leave empty to fall back to https://promptdrop-web.vercel.app
VITE_SITE_URL=
# Google Search Console: the content value of the verification meta tag.
# Rendered as <meta name="google-site-verification"> only when set.
VITE_GOOGLE_SITE_VERIFICATION=

# ---- Analytics (all optional; site works with none of these set) ----
# Master switch. Events are no-ops (dev-logged) unless this is "true".
VITE_ENABLE_ANALYTICS=false
# Google Analytics 4 measurement ID, e.g. G-XXXXXXXXXX
VITE_GA_MEASUREMENT_ID=
# PostHog project key + host (host defaults to https://us.i.posthog.com)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=

# Stripe checkout/portal run as Supabase Edge Functions. The Stripe SECRET key,
# webhook secret, and the four price IDs are set as Edge Function secrets ON THE
# SERVER (never in this file). See SUPABASE_STRIPE_SETUP.md.
