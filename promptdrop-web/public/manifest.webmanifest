{
  "name": "PromptDrop",
  "short_name": "PromptDrop",
  "description": "A teleprompter that lives beside your camera, follows your voice, and records the take.",
  "start_url": "/app",
  "scope": "/",
  "display": "standalone",
  "background_color": "#0A0B0F",
